{
  "name": "YYYYY",
  "version": "0.15.4-beta",
  "description": "Real-time AI copilot for interviews (beta desktop app)",
  "author": "Souvik Biswas <dev.souvikbiswas@gmail.com>",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "fix": "bunx @biomejs/biome format --write .",
    "build:electron": "node scripts/build-electron.js",
    "electron:dev": "bun run build:electron && concurrently \"PORT=3000 bun run dev\" \"wait-on http://localhost:3000 && DEV_PORT=3000 electron .\"",
    "electron:debug": "ELECTRON_DEBUG=true bun run build:electron && concurrently \"PORT=3000 bun run dev\" \"wait-on http://localhost:3000 && DEV_PORT=3000 electron .\"",
    "electron:build": "rm -f electron/DEBUG_BUILD && bun run build:electron && bun run build && node scripts/apply-app-constants.js && electron-builder",
    "electron:build:debug": "bun run build:electron && bun run build && node scripts/apply-app-constants.js && printf 'debug build · %s\\n' \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" > electron/DEBUG_BUILD && electron-builder",
    "electron:start": "bun run build:electron && electron .",
    "clean": "rm -rf .next out dist electron/*.js electron/*.js.map electron/DEBUG_BUILD"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.4.0",
    "@next/third-parties": "^16.2.9",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "better-auth": "^1.6.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.9.0",
    "next": "^16.2.9",
    "pdfjs-dist": "^5.4.54",
    "posthog-js": "^1.390.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  },
  "main": "electron/main.js",
  "trustedDependencies": [
    "electron",
    "electron-winstaller",
    "@biomejs/biome",
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "core-js",
    "unrs-resolver",
    "protobufjs",
    "workerd"
  ],
  "build": {
    "appId": "com.devsouvikbiswas.yyyyy",
    "productName": "YYYYY",
    "artifactName": "Realtime Interview Copilot Beta-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "devsouvikbiswas",
        "repo": "YYYYY",
        "releaseType": "release"
      }
    ],
    "files": [
      "out/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "constant.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icons/android-chrome-512x512.png",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "minimumSystemVersion": "11.0",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Meeting Copilot uses the microphone to transcribe your voice for the Ask AI feature.",
        "NSCameraUsageDescription": "Meeting Copilot does not record from the camera; this permission is requested only by macOS for media capture APIs and will not be used.",
        "NSAppleEventsUsageDescription": "Meeting Copilot does not script other apps; this permission is requested only by macOS for system integration.",
        "LSUIElement": false,
        "NSHighResolutionCapable": true
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/icons/favicon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devsouvikbiswas/YYYYY.git"
  }
}
